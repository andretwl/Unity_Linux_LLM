{
  "mcpServers": {
    "chrome-devtools-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--browserUrl=http://127.0.0.1:9222"
      ],
      "env": {
        "CHROME_PATH": "/home/athar/.gemini/antigravity/scratch/chrome-wrapper",
        "PUPPETEER_EXECUTABLE_PATH": "/home/athar/.gemini/antigravity/scratch/chrome-wrapper"
      }
    },
    "gladekit-unity": {
      "command": "/home/athar/.local/bin/uvx",
      "args": [
        "gladekit-mcp"
      ],
      "env": {
        "no_proxy": "localhost,127.0.0.1",
        "NO_PROXY": "localhost,127.0.0.1"
      }
    },
    "datadog": {
      "command": "npx",
      "args": [
        "-y",
        "@winor30/mcp-server-datadog"
      ],
      "env": {
        "DATADOG_API_KEY": "5cc57a1d-3b22-4a13-9c0c-e243cd1d811e",
        "DATADOG_APP_KEY": "e6146ab1-56fd-4c96-9347-2391d4f2fe62",
        "DATADOG_SITE": "us5.datadoghq.com"
      }
    },
    "unity-mcp": {
      "command": "/home/athar/.unity/relay/relay_linux",
      "args": [
        "--mcp"
      ],
      "env": {}
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "notebooks": {
      "command": "node",
      "args": [
        "/home/athar/.antigravity-ide/extensions/googlecloudtools.datacloud-0.6.1-universal/mcp_servers/cli/mcp_proxy_bundle.js",
        "notebooks-antigravityide"
      ]
    },
    "visualization": {
      "command": "node",
      "args": [
        "/home/athar/.antigravity-ide/extensions/googlecloudtools.datacloud-0.6.1-universal/mcp_servers/cli/mcp_proxy_bundle.js",
        "visualization-antigravityide"
      ]
    }
  }
}
